{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://satmouse.dev/schemas/spatial-data.json",
  "title": "SpatialData",
  "description": "6DOF spatial input data from a 3D input device. Semantic type: iot:SpatialData",
  "type": "object",
  "properties": {
    "translation": {
      "type": "object",
      "description": "Translation axes in device-native units (typically -350 to 350)",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      },
      "required": ["x", "y", "z"],
      "additionalProperties": false
    },
    "rotation": {
      "type": "object",
      "description": "Rotation axes in device-native units (typically -350 to 350)",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      },
      "required": ["x", "y", "z"],
      "additionalProperties": false
    },
    "timestamp": {
      "type": "number",
      "description": "Microsecond timestamp (performance.now() * 1000)"
    }
  },
  "required": ["translation", "rotation", "timestamp"],
  "additionalProperties": false
}
