{
  "name": "satmouse",
  "version": "0.9.1",
  "description": "6DOF spatial input bridge — streams device data to web apps over WebTransport and WebSocket",
  "repository": {
      "type": "git",
      "url": "git@github.com:kelnishi/SatMouse.git"
    },
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --format=cjs --outfile=dist/main.js --external:koffi --external:@fails-components/webtransport --external:node-hid",
    "build:client": "esbuild client/src/main.ts --bundle --format=esm --outfile=client/main.js --external:three",
    "build:sea": "bash scripts/build-sea.sh",
    "dev": "node --import=tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "generate-certs": "bash scripts/generate-dev-certs.sh"
  },
  "dependencies": {
    "@fails-components/webtransport": "^1.6.0",
    "@fails-components/webtransport-transport-http3-quiche": "^1.6.1",
    "bonjour-service": "^1.3.0",
    "koffi": "^2.9.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "esbuild": "^0.25.0",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT"
}
