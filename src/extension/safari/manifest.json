{
  "manifest_version": 2,
  "name": "SatMouse",
  "version": "1.0",
  "description": "6DOF spatial input device bridge",
  "permissions": ["nativeMessaging", "<all_urls>"],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
