{
  "manifest_version": 3,
  "name": "SatMouse",
  "version": "1.0",
  "description": "6DOF spatial input device bridge — connects web apps to SpaceMouse, gamepads, and HID devices.",
  "permissions": ["nativeMessaging"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
