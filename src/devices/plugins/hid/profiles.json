      "axes": [
        { "sourceAxis": 0, "target": "tx", "label": "Left Stick X", "deadZone": 0.15 },
        { "sourceAxis": 1, "target": "tz", "label": "Left Stick Y", "invert": true, "deadZone": 0.15 },
        { "sourceAxis": 2, "target": "rx", "label": "Right Stick X", "deadZone": 0.15 },
        { "sourceAxis": 3, "target": "rz", "label": "Right Stick Y", "invert": true, "deadZone": 0.15 },
        { "sourceAxis": 4, "target": "ty+", "label": "LT", "deadZone": 0.1 },
        { "sourceAxis": 5, "target": "ty-", "label": "RT", "deadZone": 0.1 }
      ],
      "buttons": [
