        { "sourceAxis": 0, "target": "tx", "label": "X" },
        { "sourceAxis": 1, "target": "ty", "label": "Y" },
        { "sourceAxis": 2, "target": "tz", "label": "Z" },
        { "sourceAxis": 3, "target": "rx", "label": "Pitch" },
